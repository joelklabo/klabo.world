# Production Environment Variables Template
# Copy this to .env.production and fill in your values

# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=your-smtp-password

# Admin Configuration
ADMIN_PASSWORD=choose-a-strong-password

# File Upload Directory (Azure persistent storage path)
UPLOADS_DIR=/home/site/wwwroot/uploads

# Google Analytics (optional)
GA_TRACKING_ID=UA-XXXXXXXXX-X

# Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=
NEXT_PUBLIC_APPLICATIONINSIGHTS_CONNECTION_STRING=

# Public Lightning node widget (safe to expose as connection metadata)
BITCOIN_ONCHAIN_ADDRESS=bc1qzafw20xpesnvwup6gmtx38e5j6ddjjdpc0zh78
# Optional comma-separated pool generated by the node wallet. The app rotates through it daily.
BITCOIN_ONCHAIN_ADDRESS_POOL=
LIGHTNING_NODE_ALIAS=klabo.world
LIGHTNING_NODE_PUBKEY=0276dc1ed542d0d777b518f1bd05f042847f19f312718cf1303288119a0a789a68
LIGHTNING_NODE_HOST=lnbits.klabo.world
LIGHTNING_NODE_PORT=9735
LIGHTNING_NODE_STATUS_TIMEOUT_MS=2000

# Build Version (set automatically in CI/CD)
BUILD_VERSION=local-test
